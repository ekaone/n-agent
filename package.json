{
  "name": "@ekaone/n-agent",
  "version": "0.2.0",
  "description": "Multi-agent conversation loop with human-in-the-loop support.",
  "keywords": [
    "agent",
    "typescript",
    "library",
    "llm",
    "ai",
    "multi-agent",
    "conversation-loop",
    "human-in-the-loop"
  ],
  "author": {
    "name": "Eka Prasetia",
    "email": "ekaone3033@gmail.com",
    "url": "https://prasetia.me"
  },
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters/ai-sdk": {
      "types": "./dist/adapters/ai-sdk.d.ts",
      "import": "./dist/adapters/ai-sdk.js",
      "require": "./dist/adapters/ai-sdk.cjs"
    },
    "./adapters/anthropic": {
      "types": "./dist/adapters/anthropic.d.ts",
      "import": "./dist/adapters/anthropic.js",
      "require": "./dist/adapters/anthropic.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm typecheck && pnpm tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run clean && pnpm run test && pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "ai": ">=6.0.146",
    "@anthropic-ai/sdk": ">=0.82.0"
  },
  "peerDependenciesMeta": {
    "ai": { "optional": true },
    "@anthropic-ai/sdk": { "optional": true }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "ai": "^6.0.146",
    "openai": "^6.33.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ekaone/n-agent.git"
  },
  "bugs": {
    "url": "https://github.com/ekaone/n-agent/issues"
  },
  "homepage": "https://github.com/ekaone/n-agent#readme"
}
